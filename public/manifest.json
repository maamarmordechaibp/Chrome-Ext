{
  "manifest_version": 3,
  "name": "Marketplace Catalog Generator",
  "version": "1.0.15",
  "description": "Generate professional printable PDF catalogs.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.ca/*",
        "https://www.walmart.com/*",
        "https://www.ebay.com/*",
        "https://www.aliexpress.com/*",
        "https://www.aliexpress.us/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.ca/*",
    "https://www.walmart.com/*",
    "https://www.ebay.com/*",
    "https://www.aliexpress.com/*",
    "https://www.aliexpress.us/*",
    "https://*.ssl-images-amazon.com/*",
    "https://*.media-amazon.com/*",
    "https://i.ebayimg.com/*",
    "https://i5.walmartimages.com/*",
    "https://*.alicdn.com/*",
    "https://*.googleapis.com/*",
    "https://*.firebaseio.com/*",
    "https://codelab-77107.firebaseapp.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
